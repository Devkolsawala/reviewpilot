# ===========================================
# ReviewPilot — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.
# Variables marked ✅ are needed now. Variables marked 🔲 can be added later.

# ✅ Supabase
NEXT_PUBLIC_SUPABASE_URL=https://yurlpwqyswgnhrbwgzgb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl1cmxwd3F5c3dnbmhyYndnemdiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ3NzU1MzcsImV4cCI6MjA5MDM1MTUzN30.aWO1Tda0hpLpTSGTAHo5bn8Ddol_lM0n6XbkUV8TGP8
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl1cmxwd3F5c3dnbmhyYndnemdiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDc3NTUzNywiZXhwIjoyMDkwMzUxNTM3fQ.0N-bymxCLvELaanBVBpokCMWWor9vv6I-Nd4Q23iC9g

# ✅ Razorpay (use test mode keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_STARTER=plan_xxxxx
RAZORPAY_PLAN_GROWTH=plan_xxxxx
RAZORPAY_PLAN_AGENCY=plan_xxxxx

# ✅ xAI (Grok) — primary AI provider for generating review replies
# Get your API key at https://console.x.ai
XAI_API_KEY=xai-your-key-here
XAI_MODEL=grok-4-1-fast-reasoning
XAI_BASE_URL=https://api.x.ai/v1

# ✅ Groq — powers the marketing-site chatbot widget (/api/chat)
# Get your API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# 🔲 Shared Play Store service account (Invite Email method)
# Users invite this email in Play Console → Users & Permissions
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=reviewpilot-test@reviewpilot-491710.iam.gserviceaccount.com
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
NEXT_PUBLIC_PLAY_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# 🔲 Google Business Profile (pending API approval)
GOOGLE_GBP_CLIENT_ID=
GOOGLE_GBP_CLIENT_SECRET=

# 🔲 Twilio SMS (console.log fallback when empty)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# 🔲 Resend Email (console.log fallback when empty)
RESEND_API_KEY=

# 🔲 WhatsApp Cloud API (Meta)
# App ID / Secret from Meta App Dashboard → Settings → Basic
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
# Any random string you choose; paste the SAME value in
# Meta App Dashboard → WhatsApp → Configuration → Webhook verify token.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# System-user access token for the ReviewPilot-owned dev/test number.
# Per-customer tokens for customer-owned numbers are stored encrypted in DB.
WHATSAPP_SYSTEM_USER_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_DEFAULT_PHONE_NUMBER_ID=

# 🔲 Token encryption key — 32 bytes hex-encoded (64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED to store WhatsApp per-customer access tokens at rest.
ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=generate_a_random_secret_here

# Usage limits reset period. Set to 5 for testing (resets every 5 minutes).
# Remove or leave empty for production (weekly reset).
NEXT_PUBLIC_USAGE_PERIOD_MINUTES=

# Test mode badge visible in dashboard (set to true while testing, remove for production)
NEXT_PUBLIC_TEST_MODE=
