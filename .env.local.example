# ✅ Razorpay (use test mode keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_STARTER=plan_xxxxx
RAZORPAY_PLAN_GROWTH=plan_xxxxx
RAZORPAY_PLAN_AGENCY=plan_xxxxx

# ✅ Groq (OpenAI-compatible API — mock replies when empty)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# 🔲 Google Business Profile (pending API approval)
GOOGLE_GBP_CLIENT_ID=
GOOGLE_GBP_CLIENT_SECRET=

# 🔲 Twilio SMS (console.log fallback when empty)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# 🔲 Resend Email (console.log fallback when empty)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=generate_a_random_secret_here

# Usage limits reset period. Set to 5 for testing (resets every 5 minutes).
# Remove or leave empty for production (weekly reset).
NEXT_PUBLIC_USAGE_PERIOD_MINUTES=

# Test mode badge visible in dashboard (set to true while testing, remove for production)
NEXT_PUBLIC_TEST_MODE=
